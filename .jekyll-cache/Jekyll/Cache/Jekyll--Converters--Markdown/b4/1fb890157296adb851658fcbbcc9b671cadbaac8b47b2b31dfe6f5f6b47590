</span>    <span class="n">rl</span><span class="o">.</span><span class="n">save</span><span class="p">()</span>

<span class="k">def</span> <span class="nf">eval</span><span class="p">():</span>
    <span class="n">rl</span><span class="o">.</span><span class="n">restore</span><span class="p">()</span>    <span class="c1"># 提取网络
